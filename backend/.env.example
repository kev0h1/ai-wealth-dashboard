# GoCardless Bank Account Data API - FREE TIER
# Sign up at: https://gocardless.com/bank-account-data/
# Free tier: 100 end users, unlimited API calls
# Supports 2500+ banks including all major UK banks
GOCARDLESS_SECRET_ID=your_gocardless_secret_id_here
GOCARDLESS_SECRET_KEY=your_gocardless_secret_key_here
GOCARDLESS_REDIRECT_URI=http://localhost:8000/auth/gocardless/callback

# ============================================================================
# LEGACY CONFIGURATIONS (COMPLEX - USE NORDIGEN INSTEAD)
# ============================================================================

# Monzo Developer API Configuration (Personal use only)
# MONZO_CLIENT_ID=your_monzo_client_id_here
# MONZO_CLIENT_SECRET=your_monzo_client_secret_here
# MONZO_REDIRECT_URI=http://localhost:8000/auth/monzo/callback

# TrueLayer Configuration (RESTORED & IMPROVED)
# Sign up at: https://console.truelayer.com/
TRUELAYER_CLIENT_ID=your_truelayer_client_id_here
TRUELAYER_CLIENT_SECRET=your_truelayer_client_secret_here
TRUELAYER_REDIRECT_URI=http://localhost:8000/auth/truelayer/callback

# Lloyds Open Banking API Configuration (Future)
# LLOYDS_CLIENT_ID=your_lloyds_client_id_here
# LLOYDS_CLIENT_SECRET=your_lloyds_client_secret_here
# LLOYDS_REDIRECT_URI=http://localhost:8000/auth/lloyds/callback

# Legacy TrueLayer Configuration (Optional)
# TRUELAYER_CLIENT_ID=your_truelayer_client_id_here
# TRUELAYER_CLIENT_SECRET=your_truelayer_client_secret_here
# TRUELAYER_REDIRECT_URI=http://localhost:8000/callback